r_name\"`\n    jwt.RegisteredClaims\n}\n```\n\nAccess in web handler:\n```go\nclaims := GetJWTClaimsFromContext(ctx)\nif claims == nil {\n    return nil, huma.NewError(http.StatusUnauthorized, \"unauthorized\")\n}\nuserID := claims.UserID  // Use this throughout\n```\n\n---\n\n### **3. Business Logic Handler Pattern**\n[business-logic/handlers/auth_handler.go](business-logic/handlers/auth_handler.go), [url_handler.go](business-logic/handlers/url_handler.go)\n\n```go\ntype AuthHandler struct {\n    users interfaces.UserRepository  // Injected at construction\n    isDevMode bool\n    adminEmail string\n}\n\nfunc NewAuthHandler(users interfaces.UserRepository, isDevMode bool, adminEmail string) *AuthHandler {\n    return &AuthHandler{users: users, isDevMode: isDevMode, adminEmail: adminEmail}\n}\n\nfunc (h *AuthHandler) DeleteAccount(ctx context.Context, userID int64) error {\n    // Check if user is admin\n    user, up, err := h.users.FindByUserID(ctx, userID)  // NEW METHOD NEEDED\n    if err != nil {\n        return fmt.Errorf(\"AuthHandler.DeleteAccount: %w\", err)\n    }\n    \n    if up.ProviderEmail == h.adminEmail {\n        return businesslogic.ErrUnauthorized  // 403 Forbidden\n    }\n    \n    // Delete (NO OCC for terminal action)\n    if err := h.users.DeleteUser(ctx, userID); err != nil {\n        return fmt.Errorf(\"AuthHandler.DeleteAccount: %w\", err)\n    }\n    \n    slog.Info(\"auth: user account deleted\", \"user_id\", userID)\n    return nil\n}\n```\n\n**Key difference from URL deletion:** No `LastUpdated` parameter—account deletion is terminal.\n\n---\n\n### **4. Viewmodel Pattern**\n[web/viewmodels/url.go](web/viewmodels/url.go#L92)\n\nFor DELETE endpoints, input and response are simple:\n\n```go\n// DELETE /user/account input — empty, just uses JWT claims\ntype DeleteAccountInput struct {\n    // No fields needed; claims extracted from context\n}\n\n// Response: empty body with 204 No Content status\n```\n\nThen in the route handler:\n```go\nfunc(ctx context.Context, input *viewmodels.DeleteAccountInput) (*struct{}, error) {\n    // ... call handler\n    return nil, nil  // Empty response, 204 status\n}\n```\n\n---\n\n### **5. Repository Interface & Implementation**\n[business-logic/interfaces/user_repository.go](business-logic/interfaces/user_repository.go)\n\n**Current interface** does NOT have delete. Need to add:\n\n```go\ntype UserRepository interface {\n    // ... existing methods ...\n    \n    // DeleteUser removes the user with the given ID.\n    // ON DELETE CASCADE in the DB removes all child records automatically.\n    DeleteUser(ctx context.Context, userID int64) error\n    \n    // NEW: to check if user is admin\n    FindUserWithProvider(ctx context.Context, userID int64) (*bizmodels.User, *bizmodels.UserProvider, error)\n}\n```\n\n[infrastructure/pg/repositories/user_repository.go](infrastructure/pg/repositories/user_repository.go)\n\nImplementation pattern (from existing code):\n\n```go\nfunc (r *userRepository) DeleteUser(ctx context.Context, userID int64) error {\n    result, err := r.db.NewDelete().\n        Model((*pgmodels.User)(nil)).\n        Where(\"id = ?\", userID).\n        Exec(ctx)\n    if err != nil {\n        return fmt.Errorf(\"UserRepository.DeleteUser: %w\", err)\n    }\n    \n    n, err := result.RowsAffected()\n    if err != nil {\n        return fmt.Errorf(\"UserRepository.DeleteUser rows-affected: %w\", err)\n    }\n    if n == 0 {\n        return businesslogic.ErrNotFound\n    }\n    return nil\n}\n\nfunc (r *userRepository) FindUserWithProvider(ctx context.Context, userID int64) (*bizmodels.User, *bizmodels.UserProvider, error) {\n    // Query Users and UserProviders to get provider_email\n    // Map back to business models\n}\n```\n\n---\n\n### **6. Error Mapping**\n[web/routes/errors.go](web/routes/errors.go)\n\nAlready handles all needed cases:\n```go\nfunc MapError(err error) error {\n    switch {\n    case errors.Is(err, businesslogic.ErrUnauthorized):\n       