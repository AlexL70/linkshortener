serRepository  // Injected dependency\n    // ... other dependencies\n}\n\nfunc NewFooHandler(users interfaces.UserRepository, ...) *FooHandler {\n    return &FooHandler{users: users, ...}\n}\n\nfunc (h *FooHandler) DeleteAccount(ctx context.Context, userID int64) error {\n    // Business logic only\n    // Return business errors (ErrNotFound, ErrUnauthorized, ErrConflict, ErrValidation, etc.)\n}\n```\n\n### 4. Web Layer Handler Pattern\n**Location:** [web/routes/urls.go](web/routes/urls.go)\n\nPattern for DELETE endpoint:\n```go\nhuma.Register(api, huma.Operation{\n    OperationID:   \"delete-shortened-url\",\n    Method:        http.MethodDelete,\n    Path:          \"/user/urls/{id}\",\n    Summary:       \"Delete an existing shortened URL\",\n    DefaultStatus: http.StatusNoContent,\n}, func(ctx context.Context, input *viewmodels.DeleteUrlInput) (*struct{}, error) {\n    claims := GetJWTClaimsFromContext(ctx)\n    if claims == nil {\n        return nil, huma.NewError(http.StatusUnauthorized, \"unauthorized\")\n    }\n\n    if err := h.DeleteUrl(ctx, input.ID, claims.UserID, input.LastUpdated); err != nil {\n        return nil, MapError(err)\n    }\n    return nil, nil\n})\n```\n\n### 5. Viewmodel Pattern for Delete\n**Location:** [web/viewmodels/url.go](web/viewmodels/url.go#L92)\n\nFor DELETE /user/urls/{id}:\n```go\ntype DeleteUrlInput struct {\n    ID          int64     `path:\"id\"`\n    LastUpdated time.Time `query:\"last_updated\" required:\"true\"`\n}\n// Returns: (*struct{}, error) — empty body via MapError()\n```\n\nFor DELETE /user/account (NO OCC):\n```go\ntype DeleteAccountInput struct {\n    // Empty — just use the JWT claims\n}\n// Returns: (*struct{}, error) — empty body\n```\n\n### 6. Repository Interface Pattern\n**Location:** [business-logic/interfaces/user_repository.go](business-logic/interfaces/user_repository.go)\n\nCurrent user repo interface:\n```go\ntype UserRepository interface {\n    FindByProviderID(ctx context.Context, provider models.Provider, providerUserID string) (*models.User, *models.UserProvider, error)\n    FindByProviderEmailWithSeedID(ctx context.Context, provider models.Provider, email string) (*models.User, *models.UserProvider, error)\n    UpdateProviderUserID(ctx context.Context, userProviderID int64, newProviderUserID string) error\n    CreateUserWithProvider(ctx context.Context, userName string, up *models.UserProvider) (*models.User, error)\n    // MISSING: DeleteUser(ctx context.Context, userID int64) error\n}\n```\n\n### 7. Repository Implementation Pattern (DB Layer)\n**Location:** [infrastructure/pg/repositories/user_repository.go](infrastructure/pg/repositories/user_repository.go)\n\nPattern for constructor and error handling:\n```go\ntype userRepository struct {\n    db *bun.DB\n}\n\nfunc NewUserRepository(db *bun.DB) interfaces.UserRepository {\n    return &userRepository{db: db}\n}\n\nfunc (r *userRepository) FindByProviderID(...) (..., error) {\n    // Use r.db.NewSelect()...\n    if err != nil {\n        if isNotFound(err) {\n            return nil, businesslogic.ErrNotFound\n        }\n        return nil, fmt.Errorf(\"UserRepository.FindByProviderID: %w\", err)\n    }\n    return ..., nil\n}\n```\n\n### 8. Error Mapping\n**Location:** [web/routes/errors.go](web/routes/errors.go)\n\nMaps business errors to HTTP:\n```go\nfunc MapError(err error) error {\n    switch {\n    case errors.Is(err, businesslogic.ErrNotFound):\n        return huma.Error404NotFound(\"resource not found\")\n    case errors.Is(err, businesslogic.ErrUnauthorized):\n        return huma.Error403Forbidden(\"access denied\")\n    case errors.Is(err, businesslogic.ErrConflict):\n        return huma.Error409Conflict(\"resource already exists\")\n    // ... etc\n    default:\n        slog.Error(\"unhandled business error\", \"error\", err)\n        return huma.Error500InternalServerError(\"internal server error\")\n    }\n}\n```\n\n### 9. Business Logic Models\n**Location:** [business-logic/models/user.go](business-logic/models/user.go)\n\n```go\ntype User struct {\n    ID       int64\n    UserName string\n}\n```\n\n### 10. DB Models\n**Location:** [infrastructure/pg/models/user.go](infrastructure/pg/models/user.go)\n\n```go\ntype User struct {\n    bun.BaseModel `bun:\"table:Users,alias:u\"`\n    ID        int64     `bun:\"id,pk,autoincrement\"`\n    UserName  string    `bun:\"user_name,notnull,unique\"`\n    CreatedAt time.Time `bun:\"created_at,notnull,default:current_timestamp\"`\n    UpdatedAt time.Time `bun:\"updated_at,notnull,default:current_timestamp\"`\n}\n```\n\n### 11. Mappings Pattern\n**Location:** [infrastructure/pg/mappings/user.go](infrastructure/pg/mappings/user.go)\n\n```go\nfunc UserToBusinessModel(db *pgmodels.User) *bizmodels.User {\n    return &bizmodels.User{\n        ID:       db.ID,\n        UserName: db.UserName,\n    }\n}\n```\n\n### 12. Logging Pattern\nFrom [business-logic/handlers/auth_handler.go](business-logic/handlers/auth_handler.go):\n```go\nslog.Info(\"auth: registered new user\",\n    \"user_id\", user.ID,\n    \"user_name\", user.UserName,\n    \"provider\", input.Provider,\n)\n```\n\nFor deletion (per backend-business.md):\n- Log at INFO level with `user_id` only\n- Do NOT log email or any PII\n\n### 13. Config Access\n**Location:** [config/env.go](config/env.go)\n\n- `SUPER_ADMIN_EMAIL` is a required env var (per `requiredVars`)\n- Access via `os.Getenv(\"SUPER_ADMIN_EMAIL\")`\n- Injected into handlers at startup in `main.go`\n\n### 14. Account Deletion Rules (per backend-business.md §4.1)\n- Verify user is **not** SUPER_ADMIN by comparing `provider_email` against `SUPER_ADMIN_EMAIL`\n- Return `ErrUnauthorized` if user is admin → maps to 403 Forbidden\n- NO optimistic concurrency control (LastUpdated) — it's a terminal action\n- Call `UserRepository.DeleteUser(ctx, userID)` — DB CASCADE removes child records\n- Log at INFO level with user_id only\n\n### 15. Existing Delete Pattern (URL Example)\n**Location:** [web/routes/urls.go](web/routes/urls.go#L87), [business-logic/handlers/url_handler.go](business-logic/handlers/url_handler.go#L146), [infrastructure/pg/repositories/url_repository.go](infrastructure/pg/repositories/url_repository.go#L123)\n\nURL delete uses optimistic concurrency control (lastUpdated). For user account deletion, **NO OCC needed** — it's terminal.\n\n### 16. Existing Mocks\n**Location:** [business-logic/interfaces/mocks/](business-logic/interfaces/mocks/)\n- `mock_user_repository.go`\n- `mock_url_repository.go`\n- `mock_shortcode_generator.go`\n\nGenerated via `mockgen` — patterns found in test files.\n\n## Implementation Checklist for DELETE /user/account\n\n1. **Update UserRepository interface** — add `DeleteUser(ctx context.Context, userID int64) error`\n2. **Implement in userRepository** — DELETE from Users table (CASCADE handles children)\n3. **Create AuthHandler method** — `DeleteAccount(ctx context.Context, userID int64) error`\n   - Get user's provider_email via a new repo method or existing query\n   - Check SUPER_ADMIN_EMAIL; return ErrUnauthorized if match\n   - Call repo.DeleteUser(ctx, userID)\n   - Log at INFO level with user_id\n4. **Create viewmodel** — `DeleteAccountInput` (empty), return `(*struct{}, error)`\n5. **Register endpoint in web/routes/auth.go** — on protectedAPI, returns 204 No Content\n6. **Wrap in mapper** (if needed) — likely none, already have claims\n7. **Error handling** — MapError already handles ErrUnauthorized\n\n## Missing: How to Get User's provider_email in Handler\n\nNeed to either:\n- Option A: Add method to UserRepository: `FindProviderEmailByUserID(ctx context.Context, userID int64) (string, error)`\n- Option B: Get full user with provider: `FindFullUserByID(ctx context.Context, userID int64) (*User, *UserProvider, error)`\n- Option C: Look up user first (already exists), then check provider_email\n\nMost consistent: Option A — add focused method to user repo.\n"},"tool_response":"File created successfully at: /memories/