now := time.Now()\n\tclaims := JWTClaims{\n\t\tUserID:   user.ID,\n\t\tUserName: user.UserName,\n\t\tEmail:    email,\n\t\tRegisteredClaims: jwt.RegisteredClaims{"}]},"tool_use_id":"toolu_bdrk_01EafyZrjh8A3mKD28G6NqH1__vscode-1773735574233","cwd":"/home/alexl70/src/pet/linkshortener"}

