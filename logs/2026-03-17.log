ew ClipboardEvent('paste', {\n      bubbles: true,\n      cancelable: true,\n      clipboardData: new DataTransfer(),\n    })\n    // Simulate pasting the exact email\n    pasteEvent.clipboardData!.setData('text/plain', 'alice@example.com')\n    input.dispatchEvent(pasteEvent)\n    await flushPromises()\n\n    // The input value must not have changed via paste\n    expect(input.value).toBe('')\n    expect(pasteEvent.defaultPrevented).toBe(true)\n  })\n\n  it('ignores drop events on the confirm input', async () => {\n    const store = useAuthStore()\n    await openDialog(store)\n\n    const input = document.querySelector<HTMLInputElement>('input[type=\"email\"]')!\n    const dropEvent = new DragEvent('drop', { bubbles: true, cancelable: true })\n    input.dispatchEvent(dropEvent)\n    await flushPromises()\n\n    expect(dropEvent.defaultPrevented).toBe(true)\n  })\n})\n\n// ── confirmation guard ────────────────────────────────────────────────────────\n\ndescribe('email confirmation guard', () => {"}]},"tool_use_id":"toolu_bdrk_01WAqUPgxNQqT5oviWNuL6Ka__vscode-1773735574307","cwd":"/home/alexl70/src/pet/linkshortener"}

