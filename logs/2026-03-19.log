 session JWT.\n19  type JWTClaims struct {\n19a\tUserID   int64  `json:\"user_id\"`\n19b\tUserName string `json:\"user_name\"`\n19c\tEmail    string `json:\"email\"`\n20  \tjwt.RegisteredClaims\n21  }\n22\n23  // preRegClaims are the JWT claims for a short-lived pre-registration token.\n24  type preRegClaims struct {\n24a\tProvider       bizmodels.Provider `json:\"provider\"`\n24b\tProviderUserID string             `json:\"provider_user_id\"`\n24c\tEmail          string             `json:\"email\"`\n24d\tDisplayName    string             `json:\"display_name\"`\n25  \tjwt.RegisteredClaims\n26  }\n27\n28  // generateJTI generates a cryptographically random 16-byte hex string to use as\n28a // a JWT ID (jti). This allows individual tokens to be blacklisted on logout.\n29  func generateJTI() (string, error) {\n29a\tbuf := make([]byte, 16)\n29b\tif _, err := rand.Read(buf); err != nil {\n29c\t\treturn \"\", fmt.Errorf(\"generateJTI: %w\", err)\n29d\t}\n29e\treturn hex.EncodeToString(buf), nil\n30  }\n31\n32  // CreateJWT creates a signed JWT for the given authenticated user.\n32a // Claims include user_id, user_name, email, sub, jti, iat, and exp (24-hour expiry).\n33  func CreateJWT(user *bizmodels.User, email string) (string, error) {\n34  \tjti, err := generateJTI()\n35  \tif err != nil {\n35a\t\treturn \"\", fmt.Errorf(\"CreateJWT: %w\", err)\n36  \t}\n37  \tsecret := []byte(os.Getenv(\"JWT_SECRET\"))\n38  \tnow := time.Now()\n39  \tclaims := JWTClaims{\n39a\t\tUserID:   user.ID,\n39b\t\tUserName: user.UserName,\n39c\t\tEmail:    email,\n40  \t\tRegisteredClaims: jwt.RegisteredClaims{\n40a\t\t\tID:        jti,\n40b\t\t\tSubject:   fmt.Sprintf(\"%d\", user.ID),\n40c\t\t\tIssuedAt:  jwt.NewNumericDate(now),\n40d\t\t\tExpiresAt: jwt.NewNumericDate(now.Add(24 * time.Hour)),\n41  \t\t},\n42  \t}\n43  \ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n44  \tsigned, err := token.SignedString(secret)\n44a\tif err != nil {\n44b\t\treturn \"\", fmt.Errorf(\"CreateJWT: %w\", err)\n45  \t}\n46  \treturn signed, nil\n47  }\n48\n48  // ParseJWT validates and parses a full session JWT.\n48a // Returns ErrValidation if the token is invalid, expired, or uses an unexpected signing method.\n49  func ParseJWT(tokenStr string) (*JWTClaims, error) {\n49a\tsecret := []byte(os.Getenv(\"JWT_SECRET\"))\n49b\ttoken, err := jwt.ParseWithClaims(tokenStr, &JWTClaims{}, func(t *jwt.Token) (interface{}, error) {\n49c\t\tif _, ok := t.Method.(*jwt.SigningMethodHMAC); !ok {\n49d\t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", t.Header[\"alg\"])\n49e\t\t}\n49f\t\treturn secret, nil\n50  \t})\n51  \tif err != nil {\n51a\t\treturn nil, fmt.Errorf(\"%w: %s\", businesslogic.ErrValidation, err.Error())\n52  \t}\n53\n54  \tclaims, ok := token.Claims.(*JWTClaims)\n54a\tif !ok || !token.Valid {\n54b\t\treturn nil, fmt.Errorf(\"%w: invalid token claims\", businesslogic.ErrValidation)\n55  \t}\n56\n57  \treturn claims, nil\n58  }\n59\n59  // CreatePreRegToken creates a short-lived JWT encoding the provider identity returned\n59a // by the OAuth callback for a new (not yet registered) user. Expires in 10 minutes.\n60  func CreatePreRegToken(input *bizmodels.AuthInput) (string, error) {\n61  \tsecret := []byte(os.Getenv(\"JWT_SECRET\"))\n62  \tclaims := preRegClaims{\n62a\t\tProvider:       input.Provider,\n62b\t\tProviderUserID: input.ProviderUserID,\n62c\t\tEmail:          input.Email,\n62d\t\tDisplayName:    input.DisplayName,\n63  \t\tRegisteredClaims: jwt.RegisteredClaims{\n63a\t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(preRegTokenDuration)),\n63b\t\t\tIssuedAt:  jwt.NewNumericDate(time.Now()),\n64  \t\t},\n65  \t}\n66  \ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n67  \tsigned, err := token.SignedString(secret)\n67a\tif err != nil {\n67b\t\treturn \"\", fmt.Errorf(\"CreatePreRegToken: %w\", err)\n68  \t}\n69  \treturn signed, nil\n70  }\n71\n71  // ParsePreRegToken validates and parses a pre-registration JWT.\n71a // R