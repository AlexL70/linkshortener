hTokenBody (which has a `token` field).\n48      if ('token' in result) {\n49        auth.handleCallback(result.token)\n50        router.replace('/dashboard')\n51      } else {\n52        registrationError.value = 'Registration failed. Please try again.'\n53      }\n54    } catch (err) {\n55      if (err instanceof ApiError && err.status === 409) {\n56        registrationError.value = 'Username already taken. Please choose another.'\n57      } else {\n57a       registrationError.value = 'Registration failed. Please try again.'\n58      }\n59    } finally {\n60      registrationLoading.value = false\n61    }\n62  }\n63\n64  // ── lifecycle ────────────────────────────────────────────────────────────────\n65  onMounted(() => {\n66    const params = parseHash()\n67\n68    const token = params.get('token')\n69    if (token) {\n70      auth.handleCallback(token)\n71      router.replace('/dashboard')\n72      return\n73    }\n74\n75    const preRegToken = params.get('pre_registration_token')\n76    if (preRegToken) {\n77      preRegistrationToken.value = preRegToken\n77a     userName.value = params.get('suggested_user_name') ?? ''\n78      registrationOpen.value = true\n79      loading.value = false\n80      return\n81    }\n82\n83    const error = params.get('error')\n84    callbackError.value = error ?? 'Authentication failed.'\n85    loading.value = false\n86  })\n87  </script>\n88\n89  <template>\n90    <div class=\"flex min-h-screen items-center justify-center\">\n91      <!-- Spinner while processing a direct-token redirect -->\n92      <Loader2 v-if=\"loading\" class=\"size-8 animate-spin text-muted-foreground\" />\n93\n94      <!-- Authentication error from backend -->\n95      <div v-else-if=\"callbackError\" class=\"text-center space-y-4\">\n96        <p class=\"text-destructive\">{{ callbackError }}</p>\n97        <Button variant=\"outline\" @click=\"router.replace('/')\">Go home</Button>\n98      </div>\n99\n100   <!-- Registration dialog for new OAuth users -