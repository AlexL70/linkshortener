ect_to\"); redirectTo != \"\" {\n64  \t\t\tparsed, err := url.ParseRequestURI(redirectTo)\n65  \t\t\tif err != nil || (parsed.Scheme != \"http\" && parsed.Scheme != \"https\") || parsed.Host == \"\" {\n66  \t\t\t\tc.JSON(http.StatusBadRequest, gin.H{\"error\": \"invalid redirect_to URL\"})\n67  \t\t\t\treturn\n68  \t\t\t}\n69\n70  \t\t// SECURITY: Enforce same-origin constraint on redirect_to in production.\n71  \t\t//\n72  \t\t// Without this check, any syntactically valid http/https URL passes the\n73  \t\t// format guard above. After OAuth completes, the backend appends the\n74  \t\t// user's JWT to that URL as a fragment (#token=…) and redirects the\n74a  \t\t// browser there — effectively exfiltrating the token to an arbitrary\n75  \t\t// attacker-controlled domain (open redirect + credential leak).\n76  \t\t//\n77  \t\t// In production, Caddy routes both the frontend and the backend under the\n78  \t\t// same domain (APP_BASE_URL), so every legitimate redirect_to must\n79  \t\t// originate from that domain. We compare scheme and host exactly so that\n80  \t\t// look-alike hostnames (e.g. localhost:80801 ≠ localhost:8080) are rejected.\n81  \t\t//\n82  \t\t// In dev mode the frontend runs on a different port (e.g. :5173) while\n83  \t\t// the backend runs on :8080, so APP_BASE_URL does not match the frontend\n84  \t\t// origin. We skip the check in dev — this mirrors the same carve-out in\n85  \t\t// CORSMiddleware (cors.go) and is acceptable because dev is not publicly\n86  \t\t// reachable.\n87  \t\tif os.Getenv(\"LINKSHORTENER_ENV\") != \"dev\" {\n88  \t\t\tappBase, appBaseErr := url.ParseRequestURI(os.Getenv(\"APP_BASE_URL\"))\n89  \t\t\tif appBaseErr != nil || parsed.Scheme != appBase.Scheme || parsed.Host != appBase.Host {\n90  \t\t\t\tc.JSON(http.StatusBadRequest, gin.H{\"error\": \"redirect_to URL not allowed\"})\n91  \t\t\t\treturn\n92  \t\t\t}\n93  \t\t}\n94\n95  \t\tsession, err := store.Get(c.Request, \"linkshortener_state\")\n96  \t\tif err != nil {\n97  \t\t\tslog.Error(\"auth: failed to get session for login\", \"error\", err)\n98  \t\t\tc.JSON(http.StatusInternalServerError, gin.H{\"error\": \"internal server error\"})\n99  \t\t\treturn\n100 \t\t}\n101 \t\tsession.Values[\"redirect_to\"] = redirectTo\n102 \t\tif err := session.Save(c.Request, c.Writer); err != nil {\n103 \t\t\tslog.Error(\"auth: failed to save session for login\", \"error\", err)\n104 \t\t\tc.JSON(http.StatusInternalServerError, gin.H{\"error\": \"internal server error\"})\n105 \t\t\treturn\n106 \t\t}\n107 \t}\n108\n109 \treq := gothic.GetContextWithProvider(c.Request, providerName)\n110 \tgothic.BeginAuthHandler(c.Writer, req)\n111 })\n112\n113 router.GET(\"/auth/callback\", func(c *gin.Context) {\n114 \tproviderName := c.Query(\"provider\")\n115 \tif providerName == \"\" {\n115a \t\tproviderName = string(bizmodels.ProviderGoogle)\n116 \t}\n117\n118 \t// Retrieve and clear redirect_to from the session before any other work so\n119 \t// we can use it in error redirects too.\n120 \tsession, _ := store.Get(c.Request, \"linkshortener_state\")\n121 \tredirectTo, _ := session.Values[\"redirect_to\"].(string)\n122 \tdelete(session.Values, \"redirect_to\")\n123 \t_ = session.Save(c.Request, c.Writer) //nolint:errcheck — best-effort cleanup\n124\n125 \tif redirectTo == \"\" {\n126 \t\tc.JSON(http.StatusBadRequest, gin.H{\"error\": \"missing redirect URL\"})\n127 \t\treturn\n128 \t}\n129\n130 \treq := gothic.GetContextWithProvider(c.Request, providerName)\n131 \tgothUser, err := gothic.CompleteUserAuth(c.Writer, req)\n132 \tif err != nil {\n132a \t\tslog.Error(\"auth: OAuth callback failed\", \"error\", err)\n133 \t\tc.Redirect(http.StatusFound, redirectTo+\"#error=authentication_failed\")\n134 \t\treturn\n135 \t}\n136\n137 \t// Clear the transient OAuth state cookie immediately after use.\n138 \t_ = gothic.Logout(c.Writer, c.Request) //nolint:errcheck — best-effort cleanup\n139\n140 \tinput := webmappers.GothUserToAuthInput(gothUser, bizmodels.Pro