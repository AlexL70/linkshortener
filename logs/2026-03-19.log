cludes custom headers such as Authorization)\n17b // by responding with 204 No Content and the appropriate CORS headers, skipping\n17c // JWT validation.\n18  func CORSMiddleware() gin.HandlerFunc {\n19  \tisDevMode := os.Getenv(\"LINKSHORTENER_ENV\") == \"dev\"\n20  \tallowedOriginProd := os.Getenv(\"APP_BASE_URL\")\n21\n22  \treturn func(c *gin.Context) {\n23  \t\torigin := c.Request.Header.Get(\"Origin\")\n23a\t\tif origin == \"\" {\n23b\t\t\t// Not a cross-origin request — nothing to do.\n23c\t\t\tc.Next()\n23d\t\t\treturn\n23e\t\t}\n24\n25  \t\tvar allow bool\n25a\t\tif isDevMode {\n25b\t\t\tallow = true\n25c\t\t} else {\n25d\t\t\tallow = origin == allowedOriginProd\n25e\t\t}\n26\n27  \t\tif !allow {\n27a\t\t\tc.Next()\n27b\t\t\treturn\n27c\t\t}\n28\n29  \t\tc.Header(\"Access-Control-Allow-Origin\", origin)\n29a\t\tc.Header(\"Access-Control-Allow-Methods\", \"GET, POST, PUT, PATCH, DELETE, OPTIONS\")\n29b\t\tc.Header(\"Access-Control-Allow-Headers\", \"Origin, Content-Type, Accept, Authorization\")\n30  \t\tc.Header(\"Access-Control-Max-Age\", \"86400\")\n31\n32  \t\t// Respond to preflight and stop further handler processing.\n33  \t\tif c.Request.Method == http.MethodOptions {\n33a\t\t\tc.AbortWithStatus(http.StatusNoContent)\n33b\t\t\treturn\n33c\t\t}\n34\n35  \t\tc.Next()\n36  \t}\n```\n\n---\n\n## **6. Frontend/src/lib/api/core/OpenAPI.ts** — FULL CONTENT\n\n```typescript\n1   /* generated using openapi-typescript-codegen -- do not edit */\n2   /* istanbul ignore file */\n3   /* tslint:disable */\n4   /* eslint-disable */\n5   import type { ApiRequestOptions } from './ApiRequestOptions';\n6\n7   type Resolver<T> = (options: ApiRequestOptions) => Promise<T>;\n8   type Headers = Record<string, string>;\n9\n10  export type OpenAPIConfig = {\n10a\tBASE: string;\n10b\tVERSION: string;\n10c\tWITH_CREDENTIALS: boolean;\n10d\tCREDENTIALS: 'include' | 'omit' | 'same-origin';\n10e\tTOKEN?: string | Resolver<string> | undefined;\n10f\tUSERNAME?: string | Resolver<str