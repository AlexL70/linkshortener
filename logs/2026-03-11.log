\t// Unparseable DSN — mask the whole value to avoid leaking anything.\n\t\t\treturn \"****\"\n\t\t}\n\t\tif u.User != nil {\n\t\t\tif _, hasPassword := u.User.Password(); hasPassword {\n\t\t\t\tu.User = url.UserPassword(u.User.Username(), \"****\")\n\t\t\t}\n\t\t}\n\t\treturn u.String()\n\t}\n\n\t// key=value format: mask the password= token.\n\tparts := strings.Fields(dsn)\n\tfor i, part := range parts {\n\t\tif strings.HasPrefix(strings.ToLower(part), \"password=\") {\n\t\t\teq := strings.IndexByte(part, '=')\n\t\t\tparts[i] = part[:eq+1] + \"****\"\n\t\t}\n\t}\n\treturn strings.Join(parts, \" \")\n}"},"tool_use_id":"toolu_bdrk_01MsCUTCte6xszQ2cbtHGPh5__vscode-1773228896481","cwd":"/home/alexl70/src/pet/linkshortener"}

