erNoAuth(h *handlers.UrlHandler) *gin.Engine {\n42. \tgin.SetMode(gin.TestMode)\n43. \trouter := gin.New()\n44. \tapi := humagin.New(router, huma.DefaultConfig(\"Test API\", \"0.0.1\"))\n45. \troutes.RegisterUrlRoutes(api, h)\n46. \treturn router\n47. }\n48. \n49. // newUrlHandlerForTest creates a real UrlHandler backed by mock repo and generator.\n50. func newUrlHandlerForTest(t *testing.T, setupRepo func(*mocks.MockUrlRepository), setupGen func(*mocks.MockShortcodeGenerator)) *handlers.UrlHandler {\n51. \tt.Helper()\n52. \tctrl := gomock.NewController(t)\n53. \tmockRepo := mocks.NewMockUrlRepository(ctrl)\n54. \tmockGen := mocks.NewMockShortcodeGenerator(ctrl)\n55. \tif setupRepo != nil {\n56. \t\tsetupRepo(mockRepo)\n57. \t}\n58. \tif setupGen != nil {\n59. \t\tsetupGen(mockGen)\n60. \t}\n61. \treturn handlers.NewUrlHandler(mockRepo, mockGen, 2048, 6, 6, 10)\n62. }\n63. \n64. func TestListUserUrls_NoAuth_Returns401(t *testing.T) {\n65. \th := newUrlHandlerForTest(t, nil, nil)\n66. \tbl := routes.NewTokenBlacklist()\n67. \n68. \treq := httptest.NewRequest(http.MethodGet, \"/user/urls\", nil)\n69. \tw := httptest.NewRecorder()\n70. \n71. \tnewUrlTestRouter(h, bl).ServeHTTP(w, req)\n72. \n73. \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n74. }\n75. \n76. func TestListUserUrls_ValidJWT_ReturnsURLs(t *testing.T) {\n77. \tnow := time.Now().Truncate(time.Second)\n78. \tuser := &bizmodels.User{ID: 1, UserName: \"alice\"}\n79. \turls := []*bizmodels.ShortenedUrl{\n80. \t\t{ID: 10, UserID: 1, Shortcode: \"aaa111\", LongUrl: \"https://a.com\", CreatedAt: now, UpdatedAt: now},\n81. \t\t{ID: 11, UserID: 1, Shortcode: \"bbb222\", LongUrl: \"https://b.com\", CreatedAt: now, UpdatedAt: now},\n82. \t}\n83. \n84. \th := newUrlHandlerForTest(t, func(m *mocks.MockUrlRepository) {\n85. \t\tm.EXPECT().FindByUserID(gomock.Any(), int64(1), 1, 20).Return(urls, 2, nil)\n86. \t}, nil)\n87. \tbl := routes.NewTokenBlacklist()\n88. \n89. \ttoken, err := routes.CreateJWT(user)\n90. \trequire.NoError(t, err)\n91. \n92. \treq := httptest.NewRequest(http.MethodGet, \"/user/urls\", nil)\n93. \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n94. \tw := httptest.NewRecorder()\n95. \n96. \tnewUrlTestRouter(h, bl).ServeHTTP(w, req)\n97. \n98. \trequire.Equal(t, http.StatusOK, w.Code)\n99. \tvar body struct {\n100. \t\tItems    []map[string]interface{} `json:\"items\"`\n101. \t\tTotal    int                      `json:\"total\"`\n102. \t\tPage     int                      `json:\"page\"`\n103. \t\tPageSize int                      `json:\"page_size\"`\n104. \t}\n105. \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &body))\n106. \tassert.Equal(t, 2, body.Total)\n107. \tassert.Equal(t, 1, body.Page)\n108. \tassert.Equal(t, 20, body.PageSize)\n109. \tassert.Len(t, body.Items, 2)\n110. }\n111. \n112. func TestListUserUrls_CustomPageSize_Respected(t *testing.T) {\n113. \tos.Setenv(\"DEFAULT_PAGE_SIZE\", \"20\")\n114. \tuser := &bizmodels.User{ID: 2, UserName: \"bob\"}\n115. \th := newUrlHandlerForTest(t, func(m *mocks.MockUrlRepository) {\n116. \t\tm.EXPECT().FindByUserID(gomock.Any(), int64(2), 1, 5).Return([]*bizmodels.ShortenedUrl{}, 0, nil)\n117. \t}, nil)\n118. \tbl := routes.NewTokenBlacklist()\n119. \n120. \ttoken, err := routes.CreateJWT(user)\n121. \trequire.NoError(t, err)\n122. \n123. \treq := httptest.NewRequest(http.MethodGet, \"/user/urls?page_size=5\", nil)\n124. \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n125. \tw := httptest.NewRecorder()\n126. \n127. \tnewUrlTestRouter(h, bl).ServeHTTP(w, req)\n128. \n129. \trequire.Equal(t, http.StatusOK, w.Code)\n130. \tvar body struct {\n131. \t\tPageSize int `json:\"page_size\"`\n132. \t}\n133. \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &body))\n134. \tassert.Equal(t, 5, body.PageSize)\n135. }\n136. \n137. func TestListUserUrls_PageParam_Respected(t *testing.T) {\n138. \tuser := &bizmodels.User{ID: 3, UserName: \"carol\"}\n139. \th := newUrlHandlerForTest(t, func(m *mocks.Mock