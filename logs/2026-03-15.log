 unique shortcodes using random Base62 encoding.\ntype Base62Generator struct{}\n\n// NewShortcodeGenerator returns a Base62Generator that produces random base62 shortcodes.\nfunc NewShortcodeGenerator() *Base62Generator {\n\treturn &Base62Generator{}\n}\n\n// GenerateShortcode returns a randomly generated 6-character base62 shortcode.\nfunc (g *Base62Generator) GenerateShortcode() (string, error) {\n\tbuf := make([]byte, shortcodeLength)\n\tif _, err := rand.Read(buf); err != nil {\n\t\treturn \"\", fmt.Errorf(\"GenerateShortcode: %w\", err)\n\t}\n\tresult := make([]byte, shortcodeLength)\n\tfor i, b := range buf {\n\t\tresult[i] = base62Chars[int(b)%len(base62Chars)]\n\t}\n\treturn string(result), nil\n}"},{"filePath":"/home/alexl70/src/pet/linkshortener/backend/business-logic/shortcode.go","newString":"// ValidateCustomShortcode validates a user-supplied shortcode against the given length limits.\n// Returns ErrValidation if the shortcode length is outside [minLen, maxLen],\n// contains disallowed characters (anything other than alphanumeric and hyphens),\n// or matches a reserved word.\nfunc ValidateCustomShortcode(shortcode string, minLen, maxLen int) error {\n\tif len(shortcode) < minLen || len(shortcode) > maxLen {\n\t\tif minLen == maxLen {\n\t\t\treturn fmt.Errorf(\"%w: shortcode must be exactly %d characters\", ErrValidation, minLen)\n\t\t}\n\t\treturn fmt.Errorf(\"%w: shortcode length must be between %d and %d characters\", ErrValidation, minLen, maxLen)\n\t}","oldString":"// ValidateCustomShortcode validates a user-supplied shortcode.\n// Returns ErrValidation if the shortcode is not exactly 6 characters,\n// contains disallowed characters (anything other than alphanumeric and hyphens),\n// or matches a reserved word.\nfunc ValidateCustomShortcode(shortcode string) error {\n\tif len(shortcode) != shortcodeLength {\n\t\treturn fmt.Errorf(\"%w: shortcode must be exactly 6 characters\", ErrValidation)\n\t}"}]},"tool_use_id":"toolu_bdrk_01QzeTgWDcU63VDZVekTu