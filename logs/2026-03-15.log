llowed characters (anything other than alphanumeric and hyphens),\n// or matches a reserved word.\nfunc ValidateCustomShortcode(shortcode string) error {\n\tif len(shortcode) != shortcodeLength {\n\t\treturn fmt.Errorf(\"%w: shortcode must be exactly 6 characters\", ErrValidation)\n\t}\n\tfor _, c := range shortcode {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z') || c == '-') {\n\t\t\treturn fmt.Errorf(\"%w: shortcode must contain only alphanumeric characters and hyphens\", ErrValidation)\n\t\t}\n\t}\n\tif _, reserved := reservedShortcodes[strings.ToLower(shortcode)]; reserved {\n\t\treturn fmt.Errorf(\"%w: shortcode is reserved\", ErrValidation)\n\t}\n\treturn nil\n}\n","filePath":"/home/alexl70/src/pet/linkshortener/backend/business-logic/shortcode.go"},"tool_use_id":"toolu_bdrk_01TffKRAvVPQRSZF5FmdyZwJ__vscode-1773574791510","cwd":"/home/alexl70/src/pet/linkshortener"}

