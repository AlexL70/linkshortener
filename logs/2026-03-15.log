serWithProvider(ctx, \"urllstuser1\", up)\n47. \trequire.NoError(t, err)\n48. \tdefer cleanUsers(t, db, user.ID)\n49. \n50. \tinsertTestURL(t, db, user.ID, \"aaa111\", \"https://a.com\")\n51. \tinsertTestURL(t, db, user.ID, \"bbb222\", \"https://b.com\")\n52. \tinsertTestURL(t, db, user.ID, \"ccc333\", \"https://c.com\")\n53. \n54. \turlRepo := repositories.NewUrlRepository(db)\n55. \turls, total, err := urlRepo.FindByUserID(ctx, user.ID, 1, 20)\n56. \trequire.NoError(t, err)\n57. \tassert.Equal(t, 3, total)\n58. \tassert.Len(t, urls, 3)\n59. }\n60. \n61. func TestFindByUserID_EmptyList(t *testing.T) {\n62. \tdb := openTestDB(t)\n63. \tdefer db.Close() //nolint:errcheck\n64. \n65. \tctx := context.Background()\n66. \tuserRepo := repositories.NewUserRepository(db)\n67. \tup := &bizmodels.UserProvider{\n68. \t\tProvider:       bizmodels.ProviderGoogle,\n69. \t\tProviderUserID: \"url-empty-test-sub\",\n70. \t\tProviderEmail:  \"url-empty@example.com\",\n71. \t}\n72. \tuser, err := userRepo.CreateUserWithProvider(ctx, \"urlemptyuser\", up)\n73. \trequire.NoError(t, err)\n74. \tdefer cleanUsers(t, db, user.ID)\n75. \n76. \turlRepo := repositories.NewUrlRepository(db)\n77. \turls, total, err := urlRepo.FindByUserID(ctx, user.ID, 1, 20)\n78. \trequire.NoError(t, err)\n79. \tassert.Equal(t, 0, total)\n80. \tassert.Empty(t, urls)\n81. }\n82. \n83. func TestFindByUserID_PaginationOffset(t *testing.T) {\n84. \tdb := openTestDB(t)\n85. \tdefer db.Close() //nolint:errcheck\n86. \n87. \tctx := context.Background()\n88. \tuserRepo := repositories.NewUserRepository(db)\n89. \tup := &bizmodels.UserProvider{\n90. \t\tProvider:       bizmodels.ProviderGoogle,\n91. \t\tProviderUserID: \"url-page-test-sub\",\n92. \t\tProviderEmail:  \"url-page@example.com\",\n93. \t}\n94. \tuser, err := userRepo.CreateUserWithProvider(ctx, \"urlpageuser\", up)\n95. \trequire.NoError(t, err)\n96. \tdefer cleanUsers(t, db, user.ID)\n97. \n98. \tfor _, sc := range []string{\"pg0001\", \"pg0002\", \"pg0003\", \"pg0004\", \"pg0005\"} {\n99. \t\tinsertTestURL(t, db, user.ID, sc, \"https://paginate.com/\"+sc)\n100. \t\t// Small sleep so created_at timestamps differ and ordering is deterministic.\n101. \t\ttime.Sleep(2 * time.Millisecond)\n102. \t}\n103. \n104. \turlRepo := repositories.NewUrlRepository(db)\n105. \n106. \t// Page 1 with page size 2 should return 2 records; total is 5.\n107. \tpage1, total, err := urlRepo.FindByUserID(ctx, user.ID, 1, 2)\n108. \trequire.NoError(t, err)\n109. \tassert.Equal(t, 5, total)\n110. \tassert.Len(t, page1, 2)\n111. \n112. \t// Page 3 with page size 2 should return the 1 remaining record.\n113. \tpage3, total2, err := urlRepo.FindByUserID(ctx, user.ID, 3, 2)\n114. \trequire.NoError(t, err)\n115. \tassert.Equal(t, 5, total2)\n116. \tassert.Len(t, page3, 1)\n117. }\n118. \n119. func TestFindByUserID_IsolatedToOwner(t *testing.T) {\n120. \tdb := openTestDB(t)\n121. \tdefer db.Close() //nolint:errcheck\n122. \n123. \tctx := context.Background()\n124. \tuserRepo := repositories.NewUserRepository(db)\n125. \n126. \tup1 := &bizmodels.UserProvider{Provider: bizmodels.ProviderGoogle, ProviderUserID: \"iso-sub-1\", ProviderEmail: \"iso1@example.com\"}\n127. \tuser1, err := userRepo.CreateUserWithProvider(ctx, \"isoluser1\", up1)\n128. \trequire.NoError(t, err)\n129. \tdefer cleanUsers(t, db, user1.ID)\n130. \n131. \tup2 := &bizmodels.UserProvider{Provider: bizmodels.ProviderGoogle, ProviderUserID: \"iso-sub-2\", ProviderEmail: \"iso2@example.com\"}\n132. \tuser2, err := userRepo.CreateUserWithProvider(ctx, \"isoluser2\", up2)\n133. \trequire.NoError(t, err)\n134. \tdefer cleanUsers(t, db, user2.ID)\n135. \n136. \tinsertTestURL(t, db, user1.ID, \"u1abc1\", \"https://user1.com\")\n137. \tinsertTestURL(t, db, user2.ID, \"u2xyz1\", \"https://user2.com\")\n138. \n139. \turlRepo := repositories.NewUrlRepository(db)\n140. \n141. \turls1, total1, err := urlRepo.FindByUserID(ctx, user1.ID, 1, 20)\n142. \trequire.NoError(t, err)\n143. \tassert.Equal(t, 1, total1)\n144. \tassert.Len(t, urls1, 1)\n145. \tassert.Equal(t, user1.ID, urls1[0].UserID)\n146. \n147. \turls2, total2, err := urlRepo.FindByUserID(ctx, user2.ID, 1, 20)\n148. \trequire.NoError(t, err)\n149. \tassert.Equal(t, 1, total2)\n150. \tassert.Len(t, urls2, 1)\n151. \tassert.Equal(t, user2.ID, urls2[0].UserID)\n152. }\n153. \n154. // openTestDB opens a *bun.DB from the DATABASE_URL environment variable.\n155. // Tests are skipped when DATABASE_URL is not set (re-declared locally to keep this\n156. // file self-contained; the function is also present in user_repository_test.go but\n157. // that file is in the same package so we cannot re-declare it there — the shared\n158. // helper lives in the existing file and this call will reuse it).\n159. //\n160. // openTestDB and cleanUsers are defined in user_repository_test.go and are\n161. // accessible here since both files share the repositories_test package.\n162. \n163. // ── Create ────────────────────────────────────────────────────────────────────\n164. \n165. func TestCreate_Success(t *testing.T) {\n166. \tdb := openTestDB(t)\n167. \tdefer db.Close() //nolint:errcheck\n168. \n169. \tctx := context.Background()\n170. \tuserRepo := repositories.NewUserRepository(db)\n171. \tup := &bizmodels.UserProvider{Provider: bizmodels.ProviderGoogle, ProviderUserID: \"create-sub-1\", ProviderEmail: \"create1@example.com\"}\n172. \tuser, err := userRepo.CreateUserWithProvider(ctx, \"createuser1\", up)\n173. \trequire.NoError(t, err)\n174. \tdefer cleanUsers(t, db, user.ID)\n175. \n176. \turlRepo := repositories.NewUrlRepository(db)\n177. \tinput := &bizmodels.ShortenedUrl{\n178. \t\tUserID:    user.ID,\n179. \t\tShortcode: \"cr0001\",\n180. \t\tLongUrl:   \"https://create-test.com\",\n181. \t}\n182. \tcreated, err := urlRepo.Create(ctx, input)\n183. \trequire.NoError(t, err)\n184. \tassert.NotZero(t, created.ID)\n185. \tassert.Equal(t, \"cr0001\", created.Shortcode)\n186. \tassert.Equal(t, \"https://create-test.com\", created.LongUrl)\n187. \tassert.Equal(t, user.ID, created.UserID)\n188. \tassert.False(t, created.CreatedAt.IsZero())\n189. }\n190. \n191. func TestCreate_WithExpiry_Success(t *testing.T) {\n192. \tdb := openTestDB(t)\n193. \tdefer db.Close() //nolint:errcheck\n194. \n195. \tctx := context.Background()\n196. \tuserRepo := repositories.NewUserRepository(db)\n197. \tup := &bizmodels.UserProvider{Provider: bizmodels.ProviderGoogle, ProviderUserID: \"create-sub-exp\", ProviderEmail: \"createexp@example.com\"}\n198. \tuser, err := userRepo.CreateUserWithProvider(ctx, \"createuserexp\", up)\n199. \trequire.NoError(t, err)\n200. \tdefer cleanUsers(t, db, user.ID)\n201. \n202. \texp := time.Now().Add(24 * time.Hour).Truncate(time.Second)\n203. \turlRepo := repositories.NewUrlRepository(db)\n204. \tinput := &bizmodels.ShortenedUrl{\n205. \t\tUserID:    user.ID,\n206. \t\tShortcode: \"expurl\",\n207. \t\tLongUrl:   \"https://expiry-test.com\",\n208. \t\tExpiresAt: &exp,\n209. \t}\n210. \tcreated, err := urlRepo.Create(ctx, input)\n211. \trequire.NoError(t, err)\n212. \trequire.NotNil(t, created.ExpiresAt)\n213. \tassert.Equal(t, exp.Unix(), created.ExpiresAt.Unix())\n214. }\n215. \n216. func TestCreate_DuplicateShortcode_ReturnsConflict(t *testing.T) {\n217. \tdb := openTestDB(t)\n218. \tdefer db.Close() //nolint:errcheck\n219. \n220. \tctx := context.Background()\n221. \tuserRepo := repositories.NewUserRepository(db)\n222. \tup := &bizmodels.UserProvider{Provider: bizmodels.ProviderGoogle, ProviderUserID: \"create-sub-dup\", ProviderEmail: \"createdup@example.com\"}\n223. \tuser, err := userRepo.CreateUserWithProvider(ctx, \"createuserdup\", up)\n224. \trequire.NoError(t, err)\n225. \tdefer cleanUsers(t, db, user.ID)\n226. \n227. \turlRepo := repositories.NewUrlRepository(db)\n228. \tinput := &bizmodels.ShortenedUrl{UserID: user.ID, Shortcode: \"dup001\", LongUrl: \"https://dup.com\"}\n229. \t_, err = urlRepo.Create(ctx, input)\n230. \trequire.NoError(t, err)\n231. \n232. \t// Second insert with the same shortcode must return ErrConflict.\n233. \t_, err = urlRepo.Create(ctx, input)\n234. \trequire.Error(t, err)\n235. \tassert.ErrorIs(t, err, businesslogic.ErrConflict)\n236. }\n237. "}}

