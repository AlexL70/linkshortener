ecords, and any error.\n42. func (h *UrlHandler) ListUrls(ctx context.Context, userID int64, page, pageSize int) ([]*bizmodels.ShortenedUrl, int, error) {\n43. \turls, total, err := h.urls.FindByUserID(ctx, userID, page, pageSize)\n44. \tif err != nil {\n45. \t\treturn nil, 0, fmt.Errorf(\"UrlHandler.ListUrls: %w\", err)\n46. \t}\n47. \treturn urls, total, nil\n48. }\n49. \n50. // CreateUrl creates a new shortened URL for the given user.\n51. // If customShortcode is nil, a random Base62 shortcode is generated with up to\n52. // maxShortcodeRetries retries on collision.\n53. // Long URL validation and, when provided, custom shortcode validation are applied\n54. // before any DB operation.\n55. func (h *UrlHandler) CreateUrl(ctx context.Context, userID int64, longUrl string, customShortcode *string, expiresAt *time.Time) (*bizmodels.ShortenedUrl, error) {\n56. \tif err := businesslogic.ValidateLongUrl(longUrl, h.maxUrlLen); err != nil {\n57. \t\treturn nil, err\n58. \t}\n59. \n60. \tif customShortcode != nil {\n61. \t\tif err := businesslogic.ValidateCustomShortcode(*customShortcode, h.minShortcodeLen, h.maxShortcodeLen); err != nil {\n62. \t\t\treturn nil, err\n63. \t\t}\n64. \t\trecord := &bizmodels.ShortenedUrl{\n65. \t\t\tUserID:    userID,\n66. \t\t\tShortcode: *customShortcode,\n67. \t\t\tLongUrl:   longUrl,\n68. \t\t\tExpiresAt: expiresAt,\n69. \t\t}\n70. \t\tcreated, err := h.urls.Create(ctx, record)\n71. \t\tif err != nil {\n72. \t\t\treturn nil, fmt.Errorf(\"UrlHandler.CreateUrl: %w\", err)\n73. \t\t}\n74. \t\treturn created, nil\n75. \t}\n76. \n77. \tfor attempt := 0; attempt < h.maxShortcodeRetries; attempt++ {\n78. \t\tsc, err := h.generator.GenerateShortcode()\n79. \t\tif err != nil {\n80. \t\t\treturn nil, fmt.Errorf(\"UrlHandler.CreateUrl: shortcode generation failed: %w\", err)\n81. \t\t}\n82. \t\trecord := &bizmodels.ShortenedUrl{\n83. \t\t\tUserID:    userID,\n84. \t\t\tShortcode: sc,\n85. \t\t\tLongUrl:   longUrl,\n86. \t\t\tExpiresAt: expiresAt,\n87. \t\t}\n88. \t\tcreated, err := h.urls.Create(ctx, record)\n89. \t\tif err == nil {\n90. \t\t\treturn created, nil\n91. \t\t}\n92. \t\tif !errors.Is(err, businesslogic.ErrConflict) {\n93. \t\t\treturn nil, fmt.Errorf(\"UrlHandler.CreateUrl: %w\", err)\n94. \t\t}\n95. \t\tslog.WarnContext(ctx, \"shortcode collision, retrying\", \"attempt\", attempt+1, \"user_id\", userID)\n96. \t}\n97. \n98. \treturn nil, fmt.Errorf(\"UrlHandler.CreateUrl: %w: exhausted %d shortcode retries\", businesslogic.ErrConflict, h.maxShortcodeRetries)\n99. }\n100. "}}

