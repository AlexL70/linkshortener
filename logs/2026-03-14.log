{"timestamp":"2026-03-14T15:31:52.478Z","hook_event_name":"PreToolUse","session_id":"3a23b72d-0d6f-410c-ab38-cf8e8bac565f","transcript_path":"/home/alexl70/.vscode-server/data/User/workspaceStorage/01bd222c9e9d12cff8e6ef2465541c97/GitHub.copilot-chat/transcripts/3a23b72d-0d6f-410c-ab38-cf8e8bac565f.jsonl","tool_name":"create_file","tool_input":{"filePath":"/home/alexl70/src/pet/linkshortener/frontend/src/stores/theme.ts","content":"import { defineStore } from 'pinia'\nimport { ref } from 'vue'\n\ntype Theme = 'light' | 'dark'\n\nconst STORAGE_KEY = 'theme'\n\nfunction getSystemTheme(): Theme {\n  return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'\n}\n\nfunction applyTheme(theme: Theme) {\n  if (theme === 'dark') {\n    document.documentElement.classList.add('dark')\n  } else {\n    document.documentElement.classList.remove('dark')\n  }\n}\n\nexport const useThemeStore = defineStore('theme', () => {\n  const stored = localStorage.getItem(STORAGE_KEY) as Theme | null\n  const initial: Theme = stored ?? getSystemTheme()\n\n  const theme = ref<Theme>(initial)\n  applyTheme(initial)\n\n  function toggle() {\n    theme.value = theme.value === 'light' ? 'dark' : 'light'\n    localStorage.setItem(STORAGE_KEY, theme.value)\n    applyTheme(theme.value)\n  }\n\n  return { theme, toggle }\n})\n"},"tool_use_id":"toolu_bdrk_01Xhh8NrXeAiGuH9xKbqQENs__vscode-1773497712723","cwd":"/home/alexl70/src/pet/linkshortener"}

