nment variable.\nfunc envDuration(key string, defaultSeconds int) time.Duration {\n\treturn time.Duration(envInt(key, defaultSeconds)) * time.Second\n}\n","filePath":"/Volumes/transcend/src/pet/linkshortener/backend/infrastructure/pg/db.go"},"tool_response":"","tool_use_id":"toolu_bdrk_01QJYUxMsnkZjCPrTGpEuCBP__vscode-1772533729971","cwd":"/Volumes/transcend/src/pet/linkshortener"}

