            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "pre_registration_token": {
            "type": "string"
          },
          "user_name": {
            "maxLength": 50,
            "minLength": 3,
            "type": "string"
          }
        },
        "required": [
          "pre_registration_token",
          "user_name"
        ],
        "type": "object"
      },
      "UpdateUrlRequestBody": {
