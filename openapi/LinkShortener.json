        "type": "object"
      },
      "CreateUrlResponseBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/CreateUrlResponseBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
